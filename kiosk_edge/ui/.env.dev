# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# E-İSA Kiosk Edge UI — Development Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Svelte 5 + Vite — Kiosk kullanıcı arayüzü
# Kopyala: `cp .env.dev.example .env.local`
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── API Base URL (Development) ─────────────────────────────────────────────
# Lokal api-node servisine bağlanır
VITE_API_BASE=http://127.0.0.1:8765

# ── Feature Flags (Development) ────────────────────────────────────────────
# Debug modu aktif
VITE_DEBUG_MODE=true
# Test verileri göster
VITE_SHOW_TEST_DATA=true
# Ekran zamanlayıcılarını devre dışı bırak (kolay test için)
VITE_DISABLE_TIMERS=false

# ── Ekran Timeout Ayarları (Development - daha uzun) ───────────────────────
# İdari ekran timeout (saniye)
VITE_IDLE_TIMEOUT_SEC=300
# Kategori seçim timeout (saniye)
VITE_CATEGORY_TIMEOUT_SEC=120
# Soru cevaplama timeout (saniye)
VITE_QUESTION_TIMEOUT_SEC=180

# ── Reklam Ayarları (Development) ──────────────────────────────────────────
# Reklam strip gösterimi aktif/pasif
VITE_ADS_ENABLED=true
# Reklam debug modu
VITE_ADS_DEBUG=true

# ── QR Kod Ayarları (Development) ──────────────────────────────────────────
# QR kod timeout (saniye)
VITE_QR_TIMEOUT_SEC=120

# ── Logging (Development) ──────────────────────────────────────────────────
VITE_LOG_LEVEL=debug
# Console logları aktif
VITE_CONSOLE_LOGS=true

# ── WiFi Setup (Development - opsiyonel) ───────────────────────────────────
# WiFi setup ekranı aktif/pasif
VITE_WIFI_SETUP_ENABLED=true
