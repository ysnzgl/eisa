# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# E-İSA Kiosk Edge API Node — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# NOT: Bu dosya genel şablondur. Development/Production için:
#   - .env.dev.example (development)
#   - .env.prod.example (production)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── IoT Fleet Kimlik Doğrulama ────────────────────────────────────────────
# Backend'deki değerler ile aynı olmalı
EISA_KIOSK_FLEET_KEY=CHANGE_ME_FLEET_KEY
EISA_KIOSK_PROVISIONING_SECRET=CHANGE_ME_PROVISIONING_SECRET

# ── Kiosk Kimlik Bilgileri ────────────────────────────────────────────────
# Her kiosk için unique MAC adresi
KIOSK_MAC=CHANGE_ME_UNIQUE_MAC_ADDRESS

# ── Merkezi API Bağlantısı ────────────────────────────────────────────────
EISA_CENTRAL_API_BASE=https://api.eisa.com.tr
EISA_VERIFY_TLS=true

# ── SQLite Database ───────────────────────────────────────────────────────
EISA_SQLITE_PATH=./local.db

# ── Senkronizasyon İntervalları ───────────────────────────────────────────
EISA_PULL_INTERVAL_SEC=900
EISA_PUSH_INTERVAL_SEC=300
EISA_PING_INTERVAL_SEC=60

# ── Server Ayarları ───────────────────────────────────────────────────────
EISA_HOST=127.0.0.1
EISA_PORT=8765
EISA_DEV_MODE=false
