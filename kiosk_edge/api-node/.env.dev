# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# E-İSA Kiosk Edge API Node — Development Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Node.js + Fastify + SQLite — Kiosk'taki lokal API servisi
# Kopyala: `cp .env.dev.example .env.local`
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── IoT Fleet Kimlik Doğrulama (Development) ──────────────────────────────
# Backend'deki EISA_KIOSK_FLEET_KEY ve EISA_KIOSK_PROVISIONING_SECRET ile aynı olmalı
EISA_KIOSK_FLEET_KEY=dev_fleet_key
EISA_KIOSK_PROVISIONING_SECRET=dev_provisioning_secret

# ── Kiosk Kimlik Bilgileri (Development) ──────────────────────────────────
# Her kiosk'un unique MAC adresi (gerçek MAC veya test değeri)
KIOSK_MAC=00:11:22:33:44:55
# Kiosk uygulama anahtarı (opsiyonel)
KIOSK_APP_KEY=dev-kiosk-key

# ── Merkezi API Bağlantısı (Development) ───────────────────────────────────
EISA_CENTRAL_API_BASE=http://localhost:8000
EISA_VERIFY_TLS=false

# ── SQLite Database (Development) ──────────────────────────────────────────
EISA_SQLITE_PATH=./local_dev.db

# ── Senkronizasyon İntervalları (Development - daha sık) ───────────────────
# Pull interval: Backend'den veri çekme sıklığı (saniye)
EISA_PULL_INTERVAL_SEC=60
# Push interval: Backend'e log gönderme sıklığı (saniye)
EISA_PUSH_INTERVAL_SEC=30
# Ping interval: Health check sıklığı (saniye)
EISA_PING_INTERVAL_SEC=30

# ── Server Ayarları (Development) ──────────────────────────────────────────
EISA_HOST=127.0.0.1
EISA_PORT=8765
EISA_DEV_MODE=true

# ── Logging (Development) ──────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Printer Ayarları (Development - opsiyonel) ─────────────────────────────
# PRINTER_ENABLED=false
# PRINTER_NAME=
# PRINTER_WIDTH=80

# ── WiFi Yönetimi (Development - opsiyonel) ────────────────────────────────
# WIFI_INTERFACE=wlan0
