# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# E-İSA Web Panels — Development Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Vue 3 + Vite build sırasında etkileyen ortam değişkenleri
# Kopyala: `cp .env.dev.example .env.local`
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# API Base URL
# Dev: Vite proxy kullanılır `/api` → `http://localhost:8000` (vite.config.js'de tanımlı)
# Boş bırakılırsa same-origin kullanılır
VITE_API_BASE=http://localhost:8000

# Feature Flags (Development)
VITE_ENABLE_DEBUG_PANEL=true
VITE_ENABLE_DEV_TOOLS=true

# Analytics / Monitoring (Development - devre dışı)
# VITE_GOOGLE_ANALYTICS_ID=
# VITE_SENTRY_DSN=

# WebSocket URL (opsiyonel - real-time özellikler için)
# VITE_WS_URL=ws://localhost:8000/ws

# Map API Keys (opsiyonel)
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_MAPBOX_TOKEN=
