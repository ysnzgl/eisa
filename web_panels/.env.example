# Vue panellerini build sırasında etkileyen ortam değişkenleri.
# Kopyala: `cp .env.example .env.local`

# API tabanı — boş bırakılırsa same-origin (`/api/...`) kullanılır.
# Dev: Vite proxy `/api` → `http://localhost:8000` (vite.config.js)
# Prod: aynı domain altında ingress üzerinden proxy önerilir → boş bırak.
VITE_API_BASE=

# QR şifreleme anahtarı — kiosk ile ortak (zorunlu, 32 byte hex/base64).
# VITE_QR_SECRET=CHANGE_ME
