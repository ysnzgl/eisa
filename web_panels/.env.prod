# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# E-İSA Web Panels — Production Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ÖNEMLİ: Üretimde tüm CHANGE_ME değerlerini güçlü rastgele değerlerle değiştirin!
# Build sırasında Vue uygulamasına gömülür (Vite env system)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# API Base URL
# Production: Aynı domain altında ingress/nginx üzerinden proxy önerilir
# Boş bırakılırsa same-origin (`/api/...`) kullanılır
VITE_API_BASE=

# Feature Flags (Production)
VITE_ENABLE_DEBUG_PANEL=false
VITE_ENABLE_DEV_TOOLS=false

# Analytics / Monitoring (Production)
VITE_GOOGLE_ANALYTICS_ID=CHANGE_ME_GA_ID
VITE_SENTRY_DSN=https://CHANGE_ME@sentry.io/...
VITE_SENTRY_ENVIRONMENT=production

# WebSocket URL (Production - opsiyonel)
VITE_WS_URL=wss://api.eisa.com.tr/ws

# Map API Keys (Production - opsiyonel)
# VITE_GOOGLE_MAPS_API_KEY=CHANGE_ME
# VITE_MAPBOX_TOKEN=CHANGE_ME

# Build Optimizations
VITE_BUILD_SOURCEMAP=false
VITE_DROP_CONSOLE=true
