# ─────────────────────────────────────────────────────────────────────────────
# E-İSA Monorepo — Üretim örneği
# Kopyala: `cp .env.example .env` ve değerleri doldur.
# K8s/Rancher için `k8s/secret.example.yaml` ve `k8s/configmap.yaml` kullan.
# ─────────────────────────────────────────────────────────────────────────────

# Django — DJANGO_SECRET_KEY üretimde 50+ karakter rastgele olmalı
#   `python -c "import secrets;print(secrets.token_urlsafe(64))"`
DJANGO_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_50_CHARS
DJANGO_DEBUG=0
# Üretim: tüm host'ları virgülle listele; '*' yasak
DJANGO_ALLOWED_HOSTS=api.e-isa.local
# CORS: panel kaynaklarını listele (https zorunlu)
DJANGO_CORS_ORIGINS=https://panel.e-isa.local

# PostgreSQL — POSTGRES_PASSWORD en az 24 karakter güçlü/rastgele olmalı
POSTGRES_DB=eisa
POSTGRES_USER=eisa
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_24_CHARS_MIN
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# JWT
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=7
JWT_AUTH_COOKIE=eisa_access
JWT_REFRESH_COOKIE=eisa_refresh
JWT_COOKIE_SAMESITE=Strict
JWT_COOKIE_SECURE=True
# Aynı eTLD+1 altında çoklu subdomain için (örn: .e-isa.local). Aksi halde boş bırak.
# JWT_COOKIE_DOMAIN=.e-isa.local

# DRF rate limit (opsiyonel, varsayılanları geçersiz kılar)
THROTTLE_ANON=100/hour
THROTTLE_USER=2000/hour
THROTTLE_LOGIN=5/min
THROTTLE_ADMIN_SENSITIVE=10/hour

# RustFS (S3-compatible object storage)
RUSTFS_ENDPOINT=rustfs.internal:9000
RUSTFS_ACCESS_KEY=CHANGE_ME
RUSTFS_SECRET_KEY=CHANGE_ME
RUSTFS_BUCKET_NAME=eisa-prod
RUSTFS_SECURE=True
RUSTFS_PRESIGNED_URL_TTL_MINUTES=60

# Traefik / domain (compose üretim modu için)
ACME_EMAIL=admin@e-isa.local
PUBLIC_API_DOMAIN=api.e-isa.local
PUBLIC_PANEL_DOMAIN=panel.e-isa.local

# ─── Kiosk (kiosk_edge/.env, ayrı dosya) ─────────────────────────────────
# EISA_KIOSK_APP_KEY=...
# EISA_KIOSK_MAC=AA:BB:CC:DD:EE:FF
# EISA_CENTRAL_API_BASE=https://api.e-isa.local
# EISA_LOCAL_API_SECRET=...
# EISA_VERIFY_TLS=true
