# E-İSA Backend — Development Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Kopyala: `cp .env.dev.example .env.local`
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Django Genel Ayarlar
DJANGO_SECRET_KEY=dev-secret-key-change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.e-isa.local
DJANGO_CORS_ORIGINS=http://localhost:8080

# PostgreSQL Bağlantısı
POSTGRES_DB=eisa
POSTGRES_USER=eisa
POSTGRES_PASSWORD=eisa
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT Ayarları
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=30
JWT_AUTH_COOKIE=eisa_access_dev
JWT_REFRESH_COOKIE=eisa_refresh_dev
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_SECURE=False
# JWT_COOKIE_DOMAIN=

# DRF Rate Limiting (Development - daha gevşek)
THROTTLE_ANON=1000/hour
THROTTLE_USER=5000/hour
THROTTLE_LOGIN=20/min
THROTTLE_ADMIN_SENSITIVE=50/hour

# RustFS / Object Storage (Development)
RUSTFS_ENDPOINT=localhost:9000
RUSTFS_ACCESS_KEY=3oO0x1LDzqdojS6t3uQe
RUSTFS_SECRET_KEY=uOcOReROrOye3NozMuacmBj0J0zCZq7KdadSkcxX
RUSTFS_BUCKET_NAME=dev
RUSTFS_SECURE=False
RUSTFS_PRESIGNED_URL_TTL_MINUTES=120

# Kiosk Fleet Management (Development)
EISA_KIOSK_FLEET_KEY=dev_fleet_key
EISA_KIOSK_PROVISIONING_SECRET=dev_provisioning_secret

# Logging
LOG_LEVEL=DEBUG
